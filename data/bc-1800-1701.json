    "year": -1766,
    "dynasties": [],
    "events": [
      {
        "title": "商汤灭夏",
        "description": "夏朝末年夏桀暴虐无道奢侈享乐鱼肉百姓。夏桀修建高大的瑶台酒池肉林对民众进行残酷的剥削和压迫。他还自比太阳百姓指着太阳咒骂说这个太阳什么时候灭亡我们宁愿和你一起灭亡。这时东方商部落的首领汤（即成汤）在贤臣伊尹的辅佐下推行仁政得到了百姓的拥护。汤以讨伐暴君夏桀为民除害为号召起兵伐桀。商军在鸣条（今河南封丘东）与夏军展开了决战。作战之前成汤发表了著名的《汤誓》历数夏桀的罪行表明自己是替天行道。夏军将士大多不愿为暴君效力纷纷溃散夏桀战败逃奔南巢（今安徽巢湖）后死于该地夏朝灭亡。成汤建立了商朝定都于亳实现了中国历史上第一次成功的改朝换代商汤革命被儒家奉为以有道伐无道的正义典范。",
        "latitude": 34.8,
        "longitude": 113.7,
        "category": "政治",
        "region": "商朝",
        "continent": "亚洲"
      }
    ]
