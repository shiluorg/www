# HTML - short cache
/index.html
  Cache-Control: public, max-age=3600

# JSON data files - 1 day
/data/*
  Cache-Control: public, max-age=86400

# JS files - 7 days
/js/*
  Cache-Control: public, max-age=604800

# CSS files - 7 days
/style.css
  Cache-Control: public, max-age=604800

# Service Worker - short cache
/sw.js
  Cache-Control: public, max-age=3600

# Static assets - 30 days
/sitemap.xml
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400